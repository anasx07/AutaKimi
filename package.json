{
  "name": "autakimi-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "github-page"
  ],
  "scripts": {
    "prepare": "husky",
    "dev:desktop": "npm run dev -w apps/desktop",
    "build:desktop": "npm run build -w apps/desktop",
    "dev:mobile": "npm run start -w apps/mobile",
    "dev:page": "npm run dev -w github-page",
    "build:page": "npm run build -w github-page",
    "lint": "eslint .",
    "format": "prettier --write .",
    "android:studio": "scripts\\open_in_android_studio.bat",
    "start:desktop": "scripts\\Start_dev.bat",
    "start:mobile": "scripts\\Start_mobile_dev.bat"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "version": "2.0.4"
}
